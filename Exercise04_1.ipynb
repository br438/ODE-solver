      "source": [
        "## tests ##\n",
        "assert is_even(0) == True\n",
        "assert is_even(101) == False\n",
        "assert is_even(982) == True\n",
        "assert is_even(-5) == False\n",
        "assert is_even(-8) == True\n",
        "\n",
        "print(\"All tests passed!\")"
