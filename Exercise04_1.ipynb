      "source": [
        "def is_even(x):\n",
        "    # Returns True if the remainder of x / 2 is 0\n",
        "    return x % 2 == 0"
      ],
      "metadata": {
        "id": "WBGsprmlT3O4"
      },
      "execution_count": 1,
      "outputs": []
    },
